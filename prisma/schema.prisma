// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CASHIER
  STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MembershipTier {
  BRONZE // 500 điểm - 5%
  SILVER // 1000 điểm - 10%
  GOLD // 2000 điểm - 15%
  PLATINUM // 5000 điểm - 20%
  DIAMOND // 10000 điểm - 25%
}

enum BonusTransactionType {
  EARNED // Tích điểm từ thanh toán
  REDEEMED // Tiêu điểm giảm tiền
  ADJUSTED // Điều chỉnh thủ công
}

model User {
  id             String         @id @default(uuid())
  username       String         @unique
  email          String         @unique
  password       String
  fullName       String         @map("full_name")
  phone          String         @unique
  role           UserRole       @default(CUSTOMER)
  status         UserStatus     @default(ACTIVE)
  bonusPoints    Int            @default(0) @map("bonus_points")
  membershipTier MembershipTier @default(BRONZE) @map("membership_tier")
  refreshToken   String?        @default("") @map("refresh_token")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relations
  createdOrders          Order[]                 @relation("CreatedByUser")
  openedSessions         TableSession[]          @relation("OpenedByCashier")
  handledSessions        TableSession[]          @relation("HandledByStaff")
  stockMovements         StockMovement[]         @relation("CreatedByUser")
  bonusTransactions      BonusTransaction[]
  notifications          Notification[]
  confirmedBookings      TableBooking[]          @relation("BookingConfirmedBy")
  tableBookings          TableBooking[]          @relation("CustomerBookings")
  customerSessions       TableSession[]          @relation("SessionCustomer")
  assignedTasks          StaffTask[]             @relation("TaskAssignee")
  createdTasks           StaffTask[]             @relation("TaskCreator")
  accountingTransactions AccountingTransaction[] @relation("AccountingCreatedBy")
  workScheduleWeeks      WorkScheduleWeek[]      @relation("ScheduleOwner")
  reviewedSchedules      WorkScheduleWeek[]      @relation("ScheduleReviewer")
  payrollAdjustments     PayrollAdjustment[]     @relation("PayrollAdjustmentTarget")
  createdPayrollAdjustments PayrollAdjustment[] @relation("PayrollAdjustmentCreator")

  @@map("users")
}

// ==================== TABLE MANAGEMENT ====================

enum TableStatus {
  AVAILABLE // Bàn trống
  OCCUPIED // Đang chơi
  RESERVED // Đã đặt
  MAINTENANCE // Bảo trì
}

model Table {
  id          String      @id @default(uuid())
  tableNumber Int         @unique @map("table_number") // Số bàn:  B1, B2, B3... 
  tableName   String      @map("table_name") // Tên bàn
  hourlyRate  Decimal     @map("hourly_rate") @db.Decimal(10, 2) // Giá theo giờ
  status      TableStatus @default(AVAILABLE)
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  sessions TableSession[]
  bookings TableBooking[]

  @@map("tables")
}

enum SessionStatus {
  ACTIVE // Đang chơi
  COMPLETED // Đã thanh toán
  CANCELLED // Đã hủy
}

model TableSession {
  id         String        @id @default(uuid())
  tableId    String        @map("table_id")
  bookingId  String?       @unique @map("booking_id") // Liên kết đặt bàn khi check-in
  customerId String?       @map("customer_id") // Khách gắn với phiên chơi
  cashierId  String?       @map("cashier_id") // Thu ngân/Cashier mở bàn (tự động gắn khi bật bàn)
  staffId    String?       @map("staff_id") // Nhân viên phục vụ thêm (tùy chọn, có thể thay đổi)
  startTime  DateTime      @default(now()) @map("start_time")
  endTime    DateTime?     @map("end_time")
  duration   Int?          @default(0) // Thời gian chơi (phút)
  tablePrice Decimal       @default(0) @map("table_price") @db.Decimal(10, 2) // Tiền bàn
  totalPrice Decimal       @default(0) @map("total_price") @db.Decimal(10, 2) // Tổng tiền (bàn + dịch vụ)
  status     SessionStatus @default(ACTIVE)
  note       String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  // Relations
  table    Table                 @relation(fields: [tableId], references: [id])
  booking  TableBooking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  customer User?                 @relation("SessionCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  cashier  User?                 @relation("OpenedByCashier", fields: [cashierId], references: [id])
  staff    User?                 @relation("HandledByStaff", fields: [staffId], references: [id])
  services TableSessionService[]
  order    Order?

  @@map("table_sessions")
}

// Dịch vụ được thêm vào bàn (đồ ăn, nước uống)
model TableSessionService {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2) // Giá tại thời điểm đặt
  subtotal  Decimal  @db.Decimal(10, 2) // quantity * price
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  session TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@map("table_session_services")
}

// ==================== PRODUCT & INVENTORY ====================

enum ProductCategory {
  FOOD // Đồ ăn
  BEVERAGE // Nước uống
  SODA // Nước ngọt
  BEER // Bia
  COFFEE // Cà phê
  EQUIPMENT // Thiết bị (phấn, cơ, ...)
  SERVICE // Dịch vụ (giá giờ chơi)
  CIGARETTE // Thuốc lá
  OTHER // Khác
}

enum ProductStatus {
  AVAILABLE
  OUT_OF_STOCK
  DISCONTINUED
}

model Product {
  id          String          @id @default(uuid())
  name        String          @unique // Tên sản phẩm
  description String?
  category    ProductCategory
  price       Decimal         @db.Decimal(10, 2) // Giá bán
  costPrice   Decimal         @map("cost_price") @db.Decimal(10, 2) // Giá vốn
  stock       Int             @default(0) // Số lượng tồn kho
  minStock    Int             @default(0) @map("min_stock") // Ngưỡng cảnh báo
  unit        String          @default("cái") // Đơn vị:  chai, lon, cái, ...
  status      ProductStatus   @default(AVAILABLE)
  imageUrl    String?         @map("image_url")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  sessionServices TableSessionService[]
  orderItems      OrderItem[]
  stockMovements  StockMovement[]

  @@map("products")
}

enum MovementType {
  IMPORT // Nhập kho
  EXPORT // Xuất kho (bán hoặc hư hỏng)
  ADJUST // Điều chỉnh
}

model StockMovement {
  id          String       @id @default(uuid())
  productId   String       @map("product_id")
  type        MovementType
  quantity    Int // Số lượng (+ là nhập, - là xuất)
  beforeStock Int          @map("before_stock") // Tồn kho trước
  afterStock  Int          @map("after_stock") // Tồn kho sau
  unitPrice   Decimal?     @map("unit_price") @db.Decimal(10, 2) // Giá nhập (nếu là IMPORT)
  totalValue  Decimal?     @map("total_value") @db.Decimal(10, 2) // Tổng giá trị
  reason      String? // Lý do xuất/nhập
  createdBy   String       @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")

  // Relations
  product Product @relation(fields: [productId], references: [id])
  user    User    @relation("CreatedByUser", fields: [createdBy], references: [id])

  @@map("stock_movements")
}

// ==================== ORDER & PAYMENT ====================

enum OrderStatus {
  PENDING // Chờ thanh toán
  PAID // Đã thanh toán
  CANCELLED // Đã hủy
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOMO
  VNPAY
  OTHER
}

model Order {
  id                 String        @id @default(uuid())
  orderNumber        String        @unique @map("order_number") // Mã hóa đơn:  HD001, HD002... 
  sessionId          String?       @unique @map("session_id") // Liên kết với session bàn (nếu có)
  customerId         String?       @map("customer_id")
  createdBy          String        @map("created_by") // Staff tạo hóa đơn
  subtotal           Decimal       @db.Decimal(10, 2) // Tổng tiền hàng
  discount           Decimal       @default(0) @db.Decimal(10, 2) // Giảm giá
  tax                Decimal       @default(0) @db.Decimal(10, 2) // Thuế (nếu có)
  total              Decimal       @db.Decimal(10, 2) // Tổng thanh toán
  bonusPointsEarned  Int           @default(0) @map("bonus_points_earned") // Điểm tích được
  bonusPointsUsed    Int           @default(0) @map("bonus_points_used") // Điểm đã dùng
  discountFromTier   Decimal       @default(0) @map("discount_from_tier") @db.Decimal(10, 2) // Giảm giá từ hạng
  discountFromPoints Decimal       @default(0) @map("discount_from_points") @db.Decimal(10, 2) // Giảm giá từ điểm
  paymentMethod      PaymentMethod @map("payment_method")
  status             OrderStatus   @default(PENDING)
  paidAt             DateTime?     @map("paid_at")
  note               String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Relations
  session           TableSession?      @relation(fields: [sessionId], references: [id])
  customer          User?              @relation("CreatedByUser", fields: [customerId], references: [id])
  items             OrderItem[]
  bonusTransactions BonusTransaction[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2) // Giá tại thời điểm bán
  subtotal  Decimal @db.Decimal(10, 2) // quantity * price

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ==================== BONUS POINT SYSTEM ====================

model BonusSettings {
  id                 String   @id @default("default")
  pointsPerVnd       Int      @default(10000) @map("points_per_vnd")
  vndPerPoint        Int      @default(1000) @map("vnd_per_point")
  maxDiscountPercent Int      @default(30) @map("max_discount_percent")
  silverThreshold    Int      @default(1000) @map("silver_threshold")
  goldThreshold      Int      @default(2000) @map("gold_threshold")
  platinumThreshold  Int      @default(5000) @map("platinum_threshold")
  diamondThreshold   Int      @default(10000) @map("diamond_threshold")
  bronzeDiscount     Int      @default(5) @map("bronze_discount")
  silverDiscount     Int      @default(10) @map("silver_discount")
  goldDiscount       Int      @default(15) @map("gold_discount")
  platinumDiscount   Int      @default(20) @map("platinum_discount")
  diamondDiscount    Int      @default(25) @map("diamond_discount")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("bonus_settings")
}

model BonusTransaction {
  id          String               @id @default(uuid())
  userId      String               @map("user_id")
  orderId     String?              @map("order_id") // Liên kết với hóa đơn (nếu có)
  type        BonusTransactionType
  points      Int // + là tích điểm, - là tiêu điểm
  description String
  createdAt   DateTime             @default(now()) @map("created_at")

  // Relations
  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@map("bonus_transactions")
}

// ==================== REPORTS (Optional - có thể tính toán từ Orders) ====================

model DailyReport {
  id              String   @id @default(uuid())
  reportDate      DateTime @unique @map("report_date") @db.Date
  totalRevenue    Decimal  @map("total_revenue") @db.Decimal(12, 2)
  totalOrders     Int      @map("total_orders")
  totalTableHours Decimal  @map("total_table_hours") @db.Decimal(10, 2)
  tableRevenue    Decimal  @map("table_revenue") @db.Decimal(12, 2)
  productRevenue  Decimal  @map("product_revenue") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("daily_reports")
}

// ==================== ACCOUNTING ====================

enum AccountingTransactionType {
  INCOME
  EXPENSE
}

enum AccountingCategory {
  TABLE_REVENUE
  PRODUCT_SALES
  IMPORT_COST
  SALARY
  UTILITIES
  MAINTENANCE
  OTHER
}

model AccountingTransaction {
  id            String                    @id @default(uuid())
  code          String                    @unique
  type          AccountingTransactionType
  category      AccountingCategory
  description   String
  amount        Decimal                   @db.Decimal(12, 2)
  paymentMethod PaymentMethod             @map("payment_method")
  createdById   String                    @map("created_by_id")
  createdAt     DateTime                  @default(now()) @map("created_at")

  createdBy User @relation("AccountingCreatedBy", fields: [createdById], references: [id])

  @@map("accounting_transactions")
}

enum DebtType {
  RECEIVABLE
  PAYABLE
}

enum DebtStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model Debt {
  id          String     @id @default(uuid())
  type        DebtType
  partnerName String     @map("partner_name")
  phone       String?
  totalAmount Decimal    @map("total_amount") @db.Decimal(12, 2)
  paidAmount  Decimal    @default(0) @map("paid_amount") @db.Decimal(12, 2)
  dueDate     DateTime   @map("due_date") @db.Date
  status      DebtStatus @default(PENDING)
  note        String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("debts")
}

// ==================== BOOKING ====================

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model TableBooking {
  id            String        @id @default(uuid())
  bookingCode   String        @unique @map("booking_code")
  customerId    String?       @map("customer_id")
  customerName  String        @map("customer_name")
  customerPhone String        @map("customer_phone")
  tableId       String        @map("table_id")
  bookingDate   DateTime      @map("booking_date") @db.Date
  startTime     String        @map("start_time")
  endTime       String        @map("end_time")
  guestCount    Int           @map("guest_count")
  depositAmount Decimal       @default(0) @map("deposit_amount") @db.Decimal(12, 2)
  note          String?
  status        BookingStatus @default(PENDING)
  confirmedById String?       @map("confirmed_by_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  table       Table         @relation(fields: [tableId], references: [id])
  customer    User?         @relation("CustomerBookings", fields: [customerId], references: [id])
  confirmedBy User?         @relation("BookingConfirmedBy", fields: [confirmedById], references: [id])
  session     TableSession?

  @@map("table_bookings")
}

// ==================== TASKS ====================

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model StaffTask {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String       @map("assignee_id")
  createdById String       @map("created_by_id")
  dueDate     DateTime     @map("due_date") @db.Date
  completedAt DateTime?    @map("completed_at")
  tags        String[]     @default([])
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  assignee  User @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy User @relation("TaskCreator", fields: [createdById], references: [id])

  @@map("staff_tasks")
}

// ==================== WORK SCHEDULE ====================

enum ShiftType {
  DAY
  EVENING
  NIGHT
}

enum WorkScheduleStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model WorkScheduleWeek {
  id           String             @id @default(uuid())
  userId       String             @map("user_id")
  weekStart    DateTime           @map("week_start") @db.Date
  status       WorkScheduleStatus @default(DRAFT)
  submittedAt  DateTime?          @map("submitted_at")
  reviewedAt   DateTime?          @map("reviewed_at")
  reviewedById String?            @map("reviewed_by_id")
  rejectReason String?            @map("reject_reason")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  user     User                    @relation("ScheduleOwner", fields: [userId], references: [id])
  reviewer User?                   @relation("ScheduleReviewer", fields: [reviewedById], references: [id])
  shifts   WorkShiftRegistration[]

  @@unique([userId, weekStart])
  @@map("work_schedule_weeks")
}

model WorkShiftRegistration {
  id        String    @id @default(uuid())
  weekId    String    @map("week_id")
  workDate  DateTime  @map("work_date") @db.Date
  shiftType ShiftType @map("shift_type")

  week WorkScheduleWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([weekId, workDate, shiftType])
  @@map("work_shift_registrations")
}

// ==================== PAYROLL ====================

model PayrollSettings {
  id               String   @id @default("default")
  dayShiftRate     Decimal  @default(150000) @map("day_shift_rate") @db.Decimal(12, 2)
  eveningShiftRate Decimal  @default(180000) @map("evening_shift_rate") @db.Decimal(12, 2)
  nightShiftRate   Decimal  @default(200000) @map("night_shift_rate") @db.Decimal(12, 2)
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("payroll_settings")
}

enum PayrollAdjustmentType {
  BONUS
  PENALTY
}

model PayrollAdjustment {
  id          String                @id @default(uuid())
  userId      String                @map("user_id")
  type        PayrollAdjustmentType
  amount      Decimal               @db.Decimal(12, 2)
  reason      String
  periodMonth DateTime              @map("period_month") @db.Date
  createdById String                @map("created_by_id")
  createdAt   DateTime              @default(now()) @map("created_at")

  user      User @relation("PayrollAdjustmentTarget", fields: [userId], references: [id])
  createdBy User @relation("PayrollAdjustmentCreator", fields: [createdById], references: [id])

  @@map("payroll_adjustments")
}

// ==================== NOTIFICATION ====================
model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  message   String
  type      NotificationType
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  USER
  STAFF
  ADMIN
  CASHIER
}
